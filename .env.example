# Custom health check message
PING_MESSAGE=pong

# Skip login/signup (local dev / preview only)
# AUTH_DISABLED=true

# Google OAuth — get credentials at https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Authorized redirect URI: http://localhost:8081/_agent-native/better-auth/callback/google
# Once set, the Google sign-in button appears automatically on the login page.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
